{
  "name": "traceweave-desktop",
  "version": "1.0.0",
  "description": "TraceWeave Desktop is the native Electron-based client for TraceWeave.",
  "main": "electron/main.js",
  "type": "module",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "start": "electron .",
    "build": "electron-builder"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "electron": "^40.8.0",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "dotenv": "^17.3.1",
    "form-data": "^4.0.5",
    "tough-cookie": "^6.0.0",
    "ws": "^8.19.0"
  },
  "build": {
    "appId": "com.traceweave.desktop",
    "productName": "TraceWeave",
    "files": [
      "electron/**/*",
      "package.json"
    ],
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage"
    },
    "mac": {
      "target": "dmg"
    }
  }
}
